{
  "expo": {
    "name": "Tours & Travel",
    "slug": "tours-and-travel",
    "scheme": "tourstravel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8F5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.toursandtravel.customer"
    },
    "android": {
      "package": "com.toursandtravel.customer",
      "adaptiveIcon": {
        "backgroundColor": "#FFF8F5",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "f70bfde1-b067-4849-9beb-72f788e98222"
      }
    },
    "owner": "ahujapiyush"
  }
}
